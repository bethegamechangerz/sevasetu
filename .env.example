# Database
DATABASE_URL=postgres://postgres:postgres@localhost:5432/sevasetu

# Better-Auth
BETTER_AUTH_SECRET=replace-with-32-byte-base64-string-from-openssl-rand-base64-32
BETTER_AUTH_URL=http://localhost:3000

# Public site
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=SevaSetu

# Map tiles (OpenStreetMap is default, no key required)
NEXT_PUBLIC_TILE_URL=https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png
NEXT_PUBLIC_TILE_ATTRIBUTION=© OpenStreetMap contributors

# Default city focus (lat, lng, label)
NEXT_PUBLIC_DEFAULT_LAT=28.6139
NEXT_PUBLIC_DEFAULT_LNG=77.2090
NEXT_PUBLIC_DEFAULT_CITY=New Delhi

# Aadhaar verification mode (demo|disabled). Real UIDAI integration is not available outside KUA/AUA license.
AADHAAR_MODE=demo
